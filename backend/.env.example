# ═══════════════════════════════════════════════════════════
# MindTrack AI v4 — Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# AI APIs (get free keys below)
GROQ_API_KEY=gsk_get_free_at_console.groq.com
ANTHROPIC_API_KEY=sk-ant-get_at_console.anthropic.com

# Database (from Supabase — free)
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Redis (from Upstash — free)
REDIS_URL=redis://default:PASSWORD@ENDPOINT.upstash.io:PORT

# Auth
SECRET_KEY=generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Email OTP (Gmail app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_16char_app_password

# Google OAuth (optional)
GOOGLE_CLIENT_ID=from_console.cloud.google.com
GOOGLE_CLIENT_SECRET=from_console.cloud.google.com

# Frontend URL (update after Vercel deploy)
FRONTEND_URL=https://mindtrack-ai.vercel.app

# Demo mode (shows OTP on screen in dev)
DEMO_MODE=true

# App
APP_ENV=development
DEBUG=true
